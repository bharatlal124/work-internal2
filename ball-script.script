 {ScrollTrigger.refresh();}, 250);}; window.addEventListener("resize", handleResize); return () => {ghostBalls.forEach(ball => {if (ball.parentNode) {ball.parentNode.removeChild(ball);}}); window.removeEventListener("resize", handleResize);};});});
</script>
